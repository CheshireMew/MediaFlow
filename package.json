{
  "name": "mediaflow",
  "version": "0.1.0",
  "description": "Modular video subtitle processing workstation",
  "private": true,
  "scripts": {
    "setup": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup/setup_windows.ps1",
    "setup:cn": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup/setup_windows.ps1 -UseChinaMirror",
    "backend:dev": ".\\.venv\\Scripts\\python.exe run.py",
    "frontend:dev": "npm run electron:dev --prefix frontend",
    "dev": "npm run frontend:dev",
    "build": "npm run build --prefix frontend",
    "preview": "npm run preview --prefix frontend",
    "install:frontend": "npm install --prefix frontend",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "powershell -Command \"$env:PYTHONPATH = $PWD; .\\.venv\\Scripts\\python.exe -m pytest tests/ --verbose\"",
    "test:frontend": "npm test --prefix frontend"
  }
}
